{
  "name": "profit-lens-qwik",
  "description": "ProfitLens Qwik parallel web app",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "preview": "qwik build preview && vite preview",
    "start": "vite --mode ssr",
    "test": "vitest run",
    "test.watch": "vitest",
    "qwik": "qwik"
  },
  "dependencies": {
    "@khmyznikov/pwa-install": "^0.6.3",
    "@qwik-ui/headless": "^0.7.4",
    "firebase": "^12.7.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.0",
    "@builder.io/qwik-city": "^1.19.0",
    "@eslint/js": "9.32.0",
    "@types/node": "20.19.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.1.0",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^2.1.8"
  }
}
