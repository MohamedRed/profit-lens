{
  "name": "profit-lens-functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "backfill:help-ticket-deliverer-status": "npm run build && node lib/scripts/backfill_help_ticket_deliverer_status.js",
    "backfill:help-ticket-timeline": "npm run build && node lib/scripts/backfill_help_ticket_timeline.js",
    "admin:sync-access": "npm run build && node lib/scripts/admin_sync_access.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google-cloud/speech": "^6.6.0",
    "csv-parse": "^6.1.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.5",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.7"
  }
}
